{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "emulators": {
        "firestore": {
            "port": 8787
        }
    },
    "functions": [{
        "source": "functions",
        "codebase": "default",
        "disallowLegacyRuntimeConfig": true,
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log",
            "*.local"
        ],
        "predeploy": [
            "npm --prefix \"$RESOURCE_DIR\" run lint"
        ]
    }]
}